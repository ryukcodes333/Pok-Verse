# ─── Required ────────────────────────────────────────────────────────────────
# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# YOUR Discord user ID — enables !dev panel and all owner-only commands
# Right-click your name in Discord → Copy User ID (enable Developer Mode first)
OWNER_ID=your_discord_id_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Bot command prefix (default: !)
PREFIX=!

# Path to the JSON database file (default: data/pokebot.json)
# DB_PATH=./data/pokebot.json

# Channel IDs where wild Pokémon can spawn (comma-separated)
# SPAWN_CHANNEL_IDS=123456789,987654321

# How often wild Pokémon spawn automatically, in minutes (default: 8)
# SPAWN_INTERVAL_MINUTES=8
